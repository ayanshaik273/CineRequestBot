# Telegram API credentials — get from https://my.telegram.org
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram user ID (numeric)
OWNER_ID=

# Channel ID where bot logs events (optional but recommended)
LOG_CHANNEL=

# *** REQUIRED: Private results channel ID (e.g. -1001234567890) ***
# The bot must be admin in this channel.
# Users must be members of this channel to see results.
RESULTS_CHANNEL=

# MongoDB full connection string (required)
# Format: mongodb+srv://<user>:<password>@<cluster>/?appName=<app>
MONGO_URI=

# Session generator secret key (required to access /gen)
# Set to any long random string — only you should know it
# Access the generator at: https://your-app.railway.app/gen?key=YOUR_SECRET
GEN_SECRET=

# Pyrogram user session string (for searching private channels)
SESSION=

# Optional
UPDATES_CHANNEL=
BACKUP_CHANNEL=
HEALTH_PORT=5000
