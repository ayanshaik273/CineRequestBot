# Telegram API credentials — get from https://my.telegram.org
API_ID=
API_HASH=

# Bot token from @BotFather
BOT_TOKEN=

# Your Telegram user ID (numeric)
OWNER_ID=

# Channel ID where bot logs events (optional but recommended)
LOG_CHANNEL=

# *** REQUIRED: Private results channel ID (e.g. -1001234567890) ***
# The bot must be admin in this channel.
# Users must be members of this channel to see results.
RESULTS_CHANNEL=

# MongoDB — one of these two:
MONGODB_PASSWORD=         # if using the shared cluster
MONGO_URI=                # or full connection string

# Pyrogram user session string (for searching private channels)
SESSION=

# Optional
UPDATES_CHANNEL=
BACKUP_CHANNEL=
HEALTH_PORT=5000
